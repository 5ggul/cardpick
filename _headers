# Cloudflare Pages — 보안·캐시 헤더
# https://developers.cloudflare.com/pages/configuration/headers/

# 전 페이지 공통 보안 헤더
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: same-site
  X-DNS-Prefetch-Control: on
  Content-Security-Policy-Report-Only: default-src 'self' https://aqxrmdratnkffvivguqs.supabase.co; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdn.tailwindcss.com https://unpkg.com https://accounts.google.com https://t1.kakaocdn.net https://developers.kakao.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com; font-src 'self' https://cdn.jsdelivr.net https://fonts.gstatic.com data:; img-src 'self' https: data: blob:; connect-src 'self' https://aqxrmdratnkffvivguqs.supabase.co https://*.supabase.co https://kapi.kakao.com https://sharer.kakao.com https://open.er-api.com; frame-src 'self' https://accounts.google.com https://sharer.kakao.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'

# HTML — MVP 안정화 전 검증 우선: no-cache (브라우저는 revalidate 강제)
/*.html
  Cache-Control: no-cache, must-revalidate

# CSS / JS — MVP 안정화 전 짧게
/*.css
  Cache-Control: no-cache, must-revalidate
/*.js
  Cache-Control: no-cache, must-revalidate

# API endpoints — no-store (functions에 추가로 설정)
/api/*
  Cache-Control: no-store, max-age=0
/cards/*
  Cache-Control: no-store, max-age=0
/hot
  Cache-Control: no-store, max-age=0

# 이미지 — 매우 긴 캐시
/*.png
  Cache-Control: public, max-age=2592000, immutable
/*.jpg
  Cache-Control: public, max-age=2592000, immutable
/*.webp
  Cache-Control: public, max-age=2592000, immutable
/*.svg
  Cache-Control: public, max-age=2592000

# JSON 데이터 — 5분 캐시 (cron 갱신 주기 반영)
/data/*.json
  Cache-Control: public, max-age=300, s-maxage=300

# 사이트맵·robots — verification 시 즉시 반영되도록 짧게 (60초)
# Daum/Naver/Google verification 시 캐시 stale 회피
/sitemap.xml
  Cache-Control: public, max-age=60
/robots.txt
  Cache-Control: public, max-age=60
/llms.txt
  Cache-Control: public, max-age=60

# RSS 2.0 피드 — 가이드 + 핫카드 데일리 갱신 (1시간 캐시)
# Naver Search Advisor / 블로그 리더 / AI 크롤러용
/rss.xml
  Cache-Control: public, max-age=3600, s-maxage=3600
